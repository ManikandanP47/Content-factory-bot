# Copy to .env and fill in values as needed.

# Paths (defaults work from project root)
CONTENT_FACTORY_ROOT=
CONTENT_FACTORY_CONFIG=config/default.yaml

# Voice: auto | kokoro | edge | macos
VOICE_PROVIDER=auto
# If edge-tts hits SSL errors on Homebrew Python, try: VOICE_PROVIDER=macos
# Ideal long-term: pip install 'content-factory[kokoro]' on Python 3.10–3.12

# Google OAuth (Drive + YouTube) — download from Google Cloud Console
GOOGLE_CLIENT_SECRETS=credentials/client_secrets.json
GOOGLE_TOKEN=credentials/token.json

# YouTube: MoticateUrself Shorts (OAuth with that channel's Google account)
YOUTUBE_PRIVACY=private
# Auto-publish channels when AUTO_PUBLISH=1 (instagram paused)
PUBLISH_CHANNELS=youtube

# Instagram Graph API — optional / paused for now
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
FACEBOOK_PAGE_ID=
# Optional public HTTPS video URL for Reels container creation
INSTAGRAM_VIDEO_URL=

# Optional overrides
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
